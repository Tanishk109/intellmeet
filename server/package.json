{
  "name": "intellmeet-server",
  "version": "2.0.0",
  "description": "IntellMeet backend — Express + MongoDB + JWT + Socket.io. Matches the IntellMeet React frontend.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "seed": "node src/utils/seed.js",
