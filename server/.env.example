# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Database ----
# Local: mongodb://127.0.0.1:27017/intellmeet
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/intellmeet
MONGO_URI=mongodb://127.0.0.1:27017/intellmeet

# ---- Auth ----
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---- CORS ----
# The Vite dev server origin (frontend)
CLIENT_ORIGIN=http://localhost:5173

# ---- Optional AI (for real summaries/captions) ----
# Leave blank to use the built-in mock AI responses the frontend already expects.
OPENAI_API_KEY=

# ---- Email invitations (Resend) ----
# Get a key at https://resend.com. Leave blank to log invites instead of sending.
RESEND_API_KEY=
# Verified sender. "onboarding@resend.dev" works for testing without a domain.
MAIL_FROM=IntellMeet <onboarding@resend.dev>

# ---- Recording uploads (Cloudinary) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Google OAuth ----
# From Google Cloud Console > APIs & Services > Credentials > OAuth client ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# This server's public origin (used to build the OAuth redirect URI).
# Local: http://localhost:5000  (or 5050 if you changed PORT)
# Prod:  https://intellmeet-api.onrender.com
SERVER_URL=http://localhost:5000
